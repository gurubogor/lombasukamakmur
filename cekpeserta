<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cek Peserta Lomba - Kecamatan Sukamakmur</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'], },
                    colors: {
                        brand: {
                            dark: '#c2410c', primary: '#f97316', secondary: '#fb923c',
                            accent: '#ffedd5', light: '#fff7ed'
                        }
                    }
                }
            }
        }
    </script>
    <style>
        .custom-scrollbar::-webkit-scrollbar { height: 6px; width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #fff7ed; border-radius: 10px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #fb923c; border-radius: 10px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #f97316; }
        .scanner-line {
            width: 100%; height: 2px; background: #f97316; position: absolute; top: 0; left: 0;
            box-shadow: 0 0 10px #f97316, 0 0 20px #f97316; animation: scan 2s infinite linear;
        }
        @keyframes scan { 0% { top: 0%; } 50% { top: 100%; } 100% { top: 0%; } }
    </style>
</head>
<body class="bg-gradient-to-b from-brand-light to-white text-gray-800 font-sans min-h-screen flex flex-col" onload="initApp()">

    <!-- MODAL CUSTOM ALERT -->
    <div id="customModal" class="fixed inset-0 bg-black bg-opacity-50 z-[80] hidden flex items-center justify-center">
        <div class="bg-white rounded-3xl shadow-2xl p-8 max-w-sm w-full mx-4 transform transition-all scale-95 border border-orange-100 relative overflow-hidden" id="modalContent">
            <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-orange-500 to-orange-400"></div>
            <div class="text-center mb-4">
                <i id="modalIcon" class="fas fa-info-circle text-5xl mb-3 text-brand-secondary"></i>
                <h3 id="modalTitle" class="text-2xl font-extrabold text-gray-900">Informasi</h3>
            </div>
            <p id="modalMessage" class="text-center text-gray-600 mb-8 text-sm md:text-base">Pesan di sini.</p>
            <button id="btn-close-modal" onclick="closeModal()" class="w-full bg-gradient-to-r from-orange-500 to-orange-400 text-white py-3.5 rounded-xl hover:from-orange-600 hover:to-orange-500 font-bold transition shadow-lg shadow-orange-500/30">Tutup</button>
        </div>
    </div>

    <!-- MODAL TAMPILKAN KARTU PESERTA -->
    <div id="modalViewPeserta" class="fixed inset-0 bg-black bg-opacity-60 z-[65] hidden flex items-center justify-center p-4">
        <div class="bg-white w-full max-w-3xl rounded-3xl shadow-2xl overflow-hidden border border-orange-100 flex flex-col max-h-[95vh]">
            <div class="p-5 border-b border-gray-100 flex justify-between items-center bg-gray-50 flex-shrink-0">
                <h3 class="font-extrabold text-lg text-gray-800"><i class="fas fa-user-circle text-blue-500 mr-2"></i> Detail Pendaftaran Peserta</h3>
                <button onclick="closeFormModal('modalViewPeserta')" class="text-gray-400 hover:text-red-500 text-xl transition"><i class="fas fa-times"></i></button>
            </div>
            <div id="view-peserta-content" class="p-6 md:p-8 space-y-4 overflow-y-auto custom-scrollbar bg-gray-100 flex-grow">
                <!-- Konten Kartu Masuk Sini -->
            </div>
        </div>
    </div>

    <!-- MODAL SCANNER QR (Opsional jika ingin diaktifkan) -->
    <div id="qrModal" class="fixed inset-0 bg-black bg-opacity-90 z-[60] hidden flex flex-col items-center justify-center p-4">
        <h3 class="text-white text-xl font-bold mb-4">Arahkan QR Code Peserta</h3>
        <div class="relative w-64 h-64 border-4 border-orange-500 rounded-lg overflow-hidden bg-gray-800 flex items-center justify-center shadow-2xl shadow-orange-500/20">
            <i class="fas fa-qrcode text-orange-600 text-9xl opacity-30"></i>
            <div class="scanner-line"></div>
        </div>
        <p class="text-orange-300 mt-4 text-sm" id="qr-status-text">Memindai...</p>
        <button onclick="closeFormModal('qrModal')" class="mt-8 bg-white text-orange-600 px-8 py-3 rounded-full font-bold hover:bg-orange-50 transition shadow-lg">Batal</button>
    </div>

    <!-- NAVIGATION BAR -->
    <nav class="bg-white text-gray-800 shadow-md sticky top-0 z-40 border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-20 items-center">
                <a href="https://gurubogor.github.io/lombasukamakmur/" class="flex items-center space-x-3 sm:space-x-4 cursor-pointer hover:opacity-80 transition max-w-[70%] sm:max-w-none">
                    <div class="h-10 sm:h-14 flex items-center justify-center overflow-hidden flex-shrink-0">
                        <img src="https://i.ibb.co.com/Wvf6CP6Y/Cover-Lomba-2.png" alt="Logo Lomba" class="h-full w-auto object-contain max-w-[80px] sm:max-w-[120px]">
                    </div>
                    <div class="min-w-0">
                        <h1 class="font-extrabold text-sm sm:text-xl leading-tight tracking-wide text-orange-600 drop-shadow-sm truncate">Portal Pendaftaran</h1>
                        <p class="text-[10px] sm:text-sm text-gray-500 font-medium mt-0.5 truncate">Kec. Sukamakmur</p>
                    </div>
                </a>
                <div class="flex items-center">
                    <a href="https://gurubogor.github.io/lombasukamakmur/" class="bg-gradient-to-r from-orange-500 to-orange-400 text-white px-4 py-2 sm:px-6 sm:py-2.5 rounded-xl font-bold hover:from-orange-600 hover:to-orange-500 transition text-xs sm:text-sm shadow-md transform hover:-translate-y-0.5 flex items-center whitespace-nowrap">
                        <i class="fas fa-home mr-1.5 sm:mr-2"></i> Home
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT CEK PESERTA -->
    <main class="flex-grow bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] bg-orange-50/50 block">
        <div class="flex flex-col items-center justify-center min-h-[80vh] px-4 sm:px-6 lg:px-8 py-12">
            <div class="max-w-lg w-full">
                <div class="text-center mb-8">
                    <div class="inline-flex items-center justify-center w-20 h-20 bg-gradient-to-br from-orange-500 to-orange-400 text-white rounded-2xl mb-4 shadow-xl shadow-orange-500/30 text-3xl transform rotate-3">
                        <i class="fas fa-id-card-alt transform -rotate-3"></i>
                    </div>
                    <h2 class="text-3xl font-extrabold text-gray-900 mt-2">Cek Data Peserta</h2>
                    <p class="text-gray-500 mt-2">Cari status pendaftaran siswa menggunakan 5 Digit ID Peserta atau scan QR Code pada kartu.</p>
                </div>

                <div class="bg-white p-6 md:p-8 rounded-3xl shadow-2xl border border-orange-100 shadow-orange-100/50 relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-orange-500 to-orange-400 z-20"></div>
                    <div class="flex flex-col space-y-5 relative z-10">
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">ID Peserta (5 Digit)</label>
                            <div class="flex space-x-3">
                                <input type="text" id="input-cek-id" maxlength="5" style="text-transform: uppercase;" class="flex-grow appearance-none rounded-xl border-2 border-gray-200 px-4 py-3 text-xl tracking-widest font-mono text-center text-gray-900 focus:outline-none focus:ring-0 focus:border-orange-500 transition-colors bg-gray-50 focus:bg-white shadow-inner" placeholder="FS2026">
                                <button onclick="cariPesertaManual()" class="bg-gradient-to-r from-orange-500 to-orange-400 hover:from-orange-600 hover:to-orange-500 text-white font-bold py-3 px-6 rounded-xl transition shadow-lg shadow-orange-500/30 transform hover:-translate-y-0.5">
                                    <i class="fas fa-search"></i>
                                </button>
                            </div>
                            <p class="text-xs text-gray-400 mt-3 text-center">Contoh: A001, B012, C105</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-white text-gray-400 py-8 border-t border-gray-100 mt-auto">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center text-sm">
            <div class="mb-4 md:mb-0 flex items-center">
                <img src="https://i.ibb.co.com/Wvf6CP6Y/Cover-Lomba-2.png" alt="Logo" class="h-10 w-auto rounded-md mr-4 grayscale opacity-50 object-contain bg-white px-1 py-1">                
                <p>&copy; FSS 2026</p>
            </div>
            <p class="font-medium text-xs bg-gray-100 px-3 py-1.5 rounded-full">Panitia Lomba Kecamatan Sukamakmur</p>
        </div>
    </footer>

    <!-- LOGIKA JAVASCRIPT KHUSUS CEK PESERTA -->
    <script>
        // GANTI DENGAN URL GOOGLE APPS SCRIPT ANDA
        const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbwgiaujeKcPpf2HQWHKZcICxsrFAlIvdgV4hq6EuGEIY40IaX14wu80BwftWIrr38YY/exec";

        let DATA_REGISTRATIONS = [];
        let globalModalTimer;

        // Fungsi inisialisasi awal saat load
        async function initApp() {
            showModal('Sedang Memuat', 'Menarik data pendaftaran dari server...', 'info', true, 0);
            
            // Tambahkan listener untuk input enter
            document.getElementById('input-cek-id').addEventListener('keypress', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    cariPesertaManual();
                }
            });

            await fetchDatabase();
        }

        // Fungsi fetch data dari Google Apps Script
        async function fetchDatabase() {
            try {
                const response = await fetch(SCRIPT_URL + "?action=getAll").then(r => r.json()).catch(() => null);
                if (response && response.status === 'success') {
                    DATA_REGISTRATIONS = response.data.pendaftaran || [];
                    closeModal(); // Tutup modal loading
                } else {
                    showModal('Gagal Memuat', 'Gagal terhubung ke database panitia.', 'error');
                }
            } catch (error) {
                console.error(error);
                showModal('Error Jaringan', 'Periksa koneksi internet Anda.', 'error');
            }
        }

        // --- MANAJEMEN UI & MODAL ---
        function toggleScaleModal(modalId, contentId, show) {
            const modal = document.getElementById(modalId);
            const content = document.getElementById(contentId);
            if(!modal || !content) return;

            if (show) {
                modal.classList.remove('hidden');
                setTimeout(() => { content.classList.remove('scale-95'); content.classList.add('scale-100'); }, 10);
            } else {
                content.classList.remove('scale-100'); content.classList.add('scale-95');
                setTimeout(() => { modal.classList.add('hidden'); }, 200);
            }
        }

        function showModal(title, message, type = 'info', hideBtn = false, timeout = 3000) {
            document.getElementById('modalTitle').innerText = title;
            document.getElementById('modalMessage').innerHTML = message;
            
            const icon = document.getElementById('modalIcon');
            if(type === 'success') icon.className = 'fas fa-check-circle text-5xl mb-3 text-green-500';
            else if (type === 'error') icon.className = 'fas fa-times-circle text-5xl mb-3 text-red-500';
            else icon.className = 'fas fa-info-circle text-5xl mb-3 text-orange-500';

            const btn = document.getElementById('btn-close-modal');
            hideBtn ? btn.classList.add('hidden') : btn.classList.remove('hidden');

            toggleScaleModal('customModal', 'modalContent', true);

            clearTimeout(globalModalTimer);
            if(timeout > 0) globalModalTimer = setTimeout(() => closeModal(), timeout);
        }

        function closeModal() {
            clearTimeout(globalModalTimer);
            toggleScaleModal('customModal', 'modalContent', false);
        }

        function openFormModal(modalId) { document.getElementById(modalId).classList.remove('hidden'); }
        function closeFormModal(modalId) { document.getElementById(modalId).classList.add('hidden'); }

        // --- PENCARIAN PESERTA ---
        function cariPesertaManual() {
            const idInput = document.getElementById('input-cek-id').value.trim().toUpperCase();
            if(idInput.length !== 5) { 
                showModal('Format Salah', 'Harap masukkan persis 5 digit ID Peserta. Contoh: A001', 'error'); 
                return; 
            }
            prosesCariPeserta(idInput);
        }

        function prosesCariPeserta(idCari) {
            const idCariKapital = String(idCari).toUpperCase();
            
            // Cari peserta yang statusnya fix 'terdaftar' (disetujui)
            const peserta = DATA_REGISTRATIONS.find(p => String(p.idPeserta).toUpperCase() === idCariKapital && p.status === 'terdaftar');          
            
            if(peserta) {
                // Jika ketemu dan disetujui, tampilkan Kartu ID
                viewPesertaDataPublic(peserta.id);
            } else {
                // Cek apakah sebenarnya ID itu ada tapi statusnya belum 'terdaftar'
                const pesertaPending = DATA_REGISTRATIONS.find(p => String(p.idPeserta).toUpperCase() === idCariKapital);
                
                if (pesertaPending) {
                     const pesanPending = `Mohon maaf, pendaftaran dengan ID "${idCariKapital}" masih dalam proses verifikasi atau perlu perbaikan berkas. Silakan hubungi Operator Sekolah Anda.`;
                     showModal('Sedang Diproses', pesanPending, 'info', false, 5000);
                } else {
                     const pesanNotFound = `Peserta dengan ID "${idCariKapital}" tidak ditemukan dalam sistem. Pastikan 5 digit ID yang Anda ketik sudah benar.`;
                     showModal('Tidak Ditemukan', pesanNotFound, 'error', false, 5000);
                }
            }
        }

        // Helper Fungsi Singkat Nama (Hanya 2 kata depan, sisanya inisial)
        function abbreviateName(name) {
            let words = name.trim().split(/\s+/);
            if (words.length <= 2) return name;
            let result = words[0] + " " + words[1];
            for (let i = 2; i < words.length; i++) {
                result += " " + words[i].charAt(0).toUpperCase() + ".";
            }
            return result;
        }

        // Helper untuk API Thumbnail Drive
        function getCleanDriveImage(url) {
            if (!url) return '';
            const match = url.match(/(?:drive\.google\.com\/file\/d\/|drive\.google\.com\/open\?id=|drive\.google\.com\/uc\?id=)([-\w]+)/);
            if (match && match[1]) {
                return `https://drive.google.com/thumbnail?id=${match[1]}&sz=w600`; 
            }
            return url;
        }

        // TAMPILAN KARTU PESERTA PUBLIK
        function viewPesertaDataPublic(id) {
            const reg = DATA_REGISTRATIONS.find(r => r.id === id);
            if(!reg) return;
            
            const statusMap = { 
                'menunggu': { label: 'Menunggu Verifikasi', class: 'bg-yellow-100 text-yellow-800 border-yellow-200' }, 
                'terdaftar': { label: 'Disetujui / Terdaftar', class: 'bg-green-100 text-green-800 border-green-200' }, 
                'ditolak': { label: 'Berkas Kurang / Ditolak', class: 'bg-red-100 text-red-800 border-red-200' } 
            };
            const statusInfo = statusMap[reg.status] || { label: reg.status, class: 'bg-gray-100 text-gray-800 border-gray-200' };
            
            const shortName = abbreviateName(reg.namaPeserta);

            const cleanFotoUrl = getCleanDriveImage(reg.fotoUrl);
            const fotoElement = reg.fotoUrl 
                ? `<img src="${cleanFotoUrl}" class="w-20 h-28 md:w-24 md:h-32 object-cover rounded-xl border-[3px] border-white shadow-md bg-gray-50 flex-shrink-0" referrerpolicy="no-referrer" alt="Foto">` 
                : `<div class="w-20 h-28 md:w-24 md:h-32 border-2 border-dashed border-gray-300 flex items-center justify-center text-gray-400 text-[10px] text-center rounded-xl bg-white shadow-sm flex-shrink-0">Foto Kosong</div>`;

            // Setup QR (API Eksternal sementara)
            const qrUrl = reg.docUrl ? `https://api.qrserver.com/v1/create-qr-code/?size=100x100&data=${encodeURIComponent(reg.docUrl)}&margin=0` : '';
            const docElement = reg.docUrl 
                ? `<div style="display: flex; align-items: center; gap: 12px; padding: 10px; border: 1px solid #e2e8f0; border-radius: 8px; background-color: #f8fafc;">
                    <img src="${qrUrl}" style="width: 65px; height: 65px; flex-shrink: 0;" alt="QR Code" referrerpolicy="no-referrer">
                    <div style="display: flex; flex-direction: column; overflow: hidden;">
                        <span style="font-size: 10px; font-weight: 800; color: #64748b; text-transform: uppercase;">Link Dokumen Berkas:</span>
                        <a href="${reg.docUrl}" target="_blank" style="font-size: 11px; color: #2563eb; text-decoration: underline; word-break: break-all; line-height: 1.3;">
                            ${reg.docUrl}
                        </a>
                    </div>
                   </div>` 
                : `<div style="padding: 10px; border: 1px dashed #cbd5e1; border-radius: 8px; text-align: center; color: #94a3b8; font-size: 12px;">Dokumen Tidak Tersedia</div>`;


            document.getElementById('view-peserta-content').innerHTML = `
                <div class="-m-2 md:-m-4">
                    <div class="w-full max-w-sm mx-auto bg-white rounded-2xl overflow-hidden shadow-lg border border-orange-200 font-sans relative">
                        
                        <div class="absolute top-0 right-0 w-40 h-40 bg-gradient-to-bl from-orange-200 to-transparent rounded-bl-full opacity-40 z-0 pointer-events-none"></div>
                        <div class="absolute bottom-0 left-0 w-32 h-32 bg-gradient-to-tr from-blue-100 to-transparent rounded-tr-full opacity-60 z-0 pointer-events-none"></div>
                        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-[0.03] z-0 pointer-events-none"></div>

                        <div class="bg-gradient-to-r from-orange-600 to-orange-400 px-[19px] py-4 flex items-center gap-3 relative z-10 shadow-sm">
                            <div class="h-16 md:h-20 max-w-[35%] flex-shrink-0 flex items-center justify-center">
                                <img src="https://i.ibb.co.com/Wvf6CP6Y/Cover-Lomba-2.png" class="h-full w-auto object-contain drop-shadow-md" alt="Logo">
                            </div>
                            
                            <div class="text-left text-white flex-grow min-w-0 flex flex-col justify-center">
                                <h2 class="text-[13px] md:text-[15px] font-black uppercase tracking-wider leading-tight drop-shadow-md break-words w-full">Kartu Peserta Lomba</h2>
                                <p class="text-[10px] md:text-xs font-semibold opacity-95 mt-0.5 uppercase tracking-wide leading-tight w-full">Tingkat Kec. Sukamakmur<br>Tahun 2026</p>
                            </div>
                        </div>

                        <div class="p-4 flex gap-4 items-center relative z-10">
                            ${fotoElement}
                            <div class="flex flex-col justify-center flex-grow min-w-0">
                                <h3 class="text-lg md:text-xl font-extrabold text-gray-900 leading-tight mb-2 truncate" title="${reg.namaPeserta}">${shortName}</h3>
                                <div class="inline-flex items-center bg-orange-50 text-orange-600 border border-orange-200 px-2 py-1 rounded-md text-[11px] font-bold tracking-widest shadow-sm w-max">
                                    <i class="fas fa-id-badge mr-1.5 opacity-70"></i> ${reg.idPeserta}
                                </div>
                            </div>
                        </div>

                        <div class="px-4 pb-4 relative z-10">
                            <div class="bg-white/80 backdrop-blur-sm rounded-xl p-3 text-left space-y-2 border border-gray-100 text-sm shadow-sm">
                                <div class="flex justify-between border-b border-gray-100 pb-1.5 items-center">
                                    <span class="text-[10px] font-bold text-gray-500 uppercase flex items-center"><i class="fas fa-fingerprint w-4 text-gray-400"></i> NISN</span>
                                    <span class="font-mono font-bold text-gray-800 text-xs">${reg.nisn}</span>
                                </div>
                                <div class="flex justify-between border-b border-gray-100 pb-1.5 items-center">
                                    <span class="text-[10px] font-bold text-gray-500 uppercase flex items-center"><i class="fas fa-school w-4 text-gray-400"></i> Asal</span>
                                    <span class="font-bold text-gray-800 text-xs text-right w-2/3 truncate" title="${reg.namaSekolah}">${reg.namaSekolah}</span>
                                </div>
                                <div class="flex justify-between items-center pt-0.5">
                                    <span class="text-[10px] font-bold text-gray-500 uppercase flex items-center"><i class="fas fa-trophy w-4 text-orange-400"></i> Lomba</span>
                                    <span class="font-extrabold text-orange-600 text-xs text-right w-2/3 truncate" title="${reg.lomba}">${reg.lomba}</span>
                                </div>
                            </div>
                        </div>

                        <div class="bg-gray-50 px-4 py-3 border-t border-gray-200 flex justify-between items-center relative z-10">
                            <span class="text-[10px] font-bold text-gray-500 uppercase">Status Verifikasi</span>
                            <span class="inline-flex items-center px-3 py-1 rounded-lg text-[10px] font-extrabold border ${statusInfo.class} shadow-sm">
                                ${statusInfo.label}
                            </span>
                        </div>
                        
                        <div class="px-4 py-3 bg-white border-t border-gray-200 mt-auto">
                            <h4 style="font-size: 12px; font-weight: 800; color: #1e293b; margin-bottom: 8px; border-left: 4px solid #f97316; padding-left: 8px;">VERIFIKASI BERKAS DIGITAL</h4>
                            ${docElement}
                        </div>

                    </div>
                </div>
            `;
            
            openFormModal('modalViewPeserta');
        }
    </script>
</body>
</html>
